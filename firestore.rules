// ─── DevoVerse Firestore Security Rules ─────────────────────────────────────
//
// Copy-paste these rules into:
//   Firebase Console → Firestore Database → Rules tab
//
// Rules summary:
//   users/{uid}         → readable/writable by the owner UID (app data sync)
//                         readable/writable by admin (account management)
//   feedbacks/{id}      → any authenticated user can create
//                         readable by the owner or admin
//                         updatable only by admin (for replies + status)
//   app_ratings/{id}    → any authenticated user can create
//                         users can read/update their own rating
//                         admin can read ratings for this app owner email
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper — true when the caller is the app admin.
    // We allow both email and UID checks to avoid provider/token edge cases.
    function isAdmin() {
      return request.auth != null
          && (
            request.auth.token.email == 'clarkcabatuan09@gmail.com'
            || request.auth.uid == 'ENSFWQhDEYWMPMZOobY0KOWSMcd2'
          );
    }

    // ── User data (per-user devotional sync + account metadata) ─────────────
    match /users/{userId} {
      // User can read/write their own document
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // Admin can read/write any user document (for oversight + disabling)
      allow read, write: if isAdmin();
    }

    // ── New sync documents (journal/settings split) ─────────────────────────
    match /userJournals/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /userSettings/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // ── Accountability partner system ───────────────────────────────────────
    match /publicProfiles/{userId} {
      // Any authenticated user can discover partner codes and read public stats.
      allow read: if request.auth != null;

      // Only owner/admin can update this profile.
      allow create, update: if request.auth != null
                            && request.auth.uid == userId;
      allow create, update: if isAdmin();

      allow delete: if false;
    }

    match /partnerRequests/{requestId} {
      // Request document ids are fromUid_toUid.
      allow read: if request.auth != null
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.toUid is string
                    && request.resource.data.fromUid != request.resource.data.toUid;

      // Sender/receiver/admin may delete (accept/reject/cleanup).
      allow delete: if request.auth != null
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid
                        || isAdmin());

      allow update: if false;
    }

    match /partnerConnections/{userId} {
      // Owner/admin can read their own partner list.
      allow read: if request.auth != null
                  && request.auth.uid == userId;
      allow read: if isAdmin();

      // Owner/admin can write their own partner list.
      allow create, update: if request.auth != null
                            && request.auth.uid == userId;
      allow create, update: if isAdmin();

      allow delete: if false;
    }

    // ── Feedback submissions ─────────────────────────────────────────────────
    match /feedbacks/{feedbackId} {
      // Any signed-in user may submit feedback
      allow create: if request.auth != null;

      // The owner or admin may read a feedback item
      allow read: if request.auth != null
                  && (resource.data.uid == request.auth.uid || isAdmin());

      // Only admin may update (e.g. add adminReply, change status)
      allow update: if isAdmin();

      // Deletion not allowed from the app
      allow delete: if false;
    }

    // ── App ratings ────────────────────────────────────────────────────────
    match /app_ratings/{ratingId} {
      // Any signed-in user may submit a rating
      allow create: if request.auth != null;

      // Owner can read their own rating; admin can read ratings for this app
      allow read: if request.auth != null
                  && (
                    resource.data.uid == request.auth.uid
                    || (isAdmin() && resource.data.appOwnerEmail == request.auth.token.email)
                  );

      // Owner may update only their own rating; admin may also update if needed
      allow update: if request.auth != null
                    && (resource.data.uid == request.auth.uid || isAdmin());

      allow delete: if false;
    }
  }
}
